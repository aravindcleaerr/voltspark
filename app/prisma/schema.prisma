generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// MULTI-TENANCY MODELS
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  website   String?
  plan      String   @default("FREE") // FREE, PRO, ENTERPRISE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients     Client[]
  memberships Membership[]
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  slug           String       @unique
  address        String?
  industry       String?
  employeeCount  Int?
  accessMode     String       @default("COLLABORATIVE") // CONSULTANT_MANAGED, COLLABORATIVE, SELF_SERVICE
  // Energy cost config
  gridTariffRate    Float?    // ₹/kWh
  solarTariffRate   Float?
  dgTariffRate      Float?
  contractDemand    Float?    // kVA
  powerFactorTarget Float?
  baselineYear      Int?
  baselineMonth     Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clientAccess       ClientAccess[]
  energySources      EnergySource[]
  consumptionEntries ConsumptionEntry[]
  trainingPrograms   TrainingProgram[]
  audits             Audit[]
  capas              CAPA[]
  auditLogs          AuditLog[]
  appSettings        AppSetting[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           String       @default("MEMBER") // OWNER, ADMIN, MEMBER
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model ClientAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  role      String   @default("EMPLOYEE") // CLIENT_ADMIN, EMPLOYEE, VIEWER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clientId])
}

// ============================================================
// USER MODEL
// ============================================================

model User {
  id           String   @id @default(cuid())
  employeeId   String?
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("USER") // PLATFORM_ADMIN, USER
  department   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships        Membership[]
  clientAccess       ClientAccess[]
  consumptionEntries ConsumptionEntry[]
  trainingAttendance TrainingAttendance[]
  auditsLed          Audit[]              @relation("AuditLead")
  capasRaised        CAPA[]               @relation("CAPARaisedBy")
  capasAssigned      CAPA[]               @relation("CAPAAssignedTo")
  capaComments       CAPAComment[]
}

// ============================================================
// ENERGY MANAGEMENT MODELS (client-scoped)
// ============================================================

model EnergySource {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  name        String
  type        String
  unit        String
  description String?
  location    String?
  meterNumber String?
  costPerUnit Float?   // ₹/kWh — overrides client-level tariff
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  targets            EnergyTarget[]
  consumptionEntries ConsumptionEntry[]
}

model EnergyTarget {
  id               String       @id @default(cuid())
  energySourceId   String
  energySource     EnergySource @relation(fields: [energySourceId], references: [id])
  period           String
  periodType       String
  targetValue      Float
  unit             String
  baselineValue    Float?
  reductionPercent Float?
  actualValue      Float?
  costTarget       Float?       // ₹ target for this period
  isActive         Boolean      @default(true)
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([energySourceId, period])
}

model ConsumptionEntry {
  id               String       @id @default(cuid())
  clientId         String
  client           Client       @relation(fields: [clientId], references: [id])
  energySourceId   String
  energySource     EnergySource @relation(fields: [energySourceId], references: [id])
  recordedById     String
  recordedBy       User         @relation(fields: [recordedById], references: [id])
  date             DateTime
  value            Float
  unit             String
  cost             Float?       // ₹ — auto-calculated from value * costPerUnit
  meterReading     Float?
  previousReading  Float?
  shift            String?
  notes            String?
  hasDeviation      Boolean      @default(false)
  deviationPercent  Float?
  deviationSeverity String?
  deviationNote     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

// ============================================================
// TRAINING MODELS (client-scoped)
// ============================================================

model TrainingProgram {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  title           String
  description     String?
  type            String
  trainer         String?
  scheduledDate   DateTime
  duration        Float?
  location        String?
  maxParticipants Int?
  materialsUrl    String?
  status          String    @default("SCHEDULED")
  completionDate  DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  attendance TrainingAttendance[]
}

model TrainingAttendance {
  id                String          @id @default(cuid())
  trainingProgramId String
  trainingProgram   TrainingProgram @relation(fields: [trainingProgramId], references: [id])
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  attended          Boolean         @default(false)
  score             Float?
  feedback          String?
  certificateIssued Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([trainingProgramId, userId])
}

// ============================================================
// AUDIT MODELS (client-scoped)
// ============================================================

model Audit {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  title           String
  type            String
  auditDate       DateTime
  leadAuditorId   String?
  leadAuditor     User?     @relation("AuditLead", fields: [leadAuditorId], references: [id])
  externalAuditor String?
  scope           String?
  status          String    @default("PLANNED")
  summary         String?
  completedDate   DateTime?
  nextAuditDate   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  findings AuditFinding[]
}

model AuditFinding {
  id             String    @id @default(cuid())
  auditId        String
  audit          Audit     @relation(fields: [auditId], references: [id])
  findingNumber  Int
  category       String
  area           String?
  description    String
  evidence       String?
  recommendation String?
  status         String    @default("OPEN")
  dueDate        DateTime?
  closedDate     DateTime?
  capaId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// CAPA MODELS (client-scoped)
// ============================================================

model CAPA {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  capaNumber      String    @unique
  type            String
  source          String
  sourceReference String?
  title           String
  description     String
  raisedById      String
  raisedBy        User      @relation("CAPARaisedBy", fields: [raisedById], references: [id])
  assignedToId    String?
  assignedTo      User?     @relation("CAPAAssignedTo", fields: [assignedToId], references: [id])
  priority        String    @default("MEDIUM")
  status          String    @default("OPEN")

  rcaMethod        String?
  rcaDetails       String?
  rootCause        String?

  correctiveAction    String?
  preventiveAction    String?
  actionDueDate       DateTime?
  actionCompletedDate DateTime?

  verificationMethod String?
  verificationDate   DateTime?
  verificationResult String?
  verifiedBy         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments CAPAComment[]
}

model CAPAComment {
  id        String   @id @default(cuid())
  capaId    String
  capa      CAPA     @relation(fields: [capaId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  comment   String
  createdAt DateTime @default(now())
}

// ============================================================
// SYSTEM MODELS
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  userId    String?
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
}

model AppSetting {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([clientId, key])
}
