generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// MULTI-TENANCY MODELS
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  website   String?
  plan      String   @default("FREE") // FREE, PRO, ENTERPRISE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients     Client[]
  memberships Membership[]
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  slug           String       @unique
  address        String?
  industry       String?
  employeeCount  Int?
  accessMode     String       @default("COLLABORATIVE") // CONSULTANT_MANAGED, COLLABORATIVE, SELF_SERVICE
  // Energy cost config
  gridTariffRate    Float?    // ₹/kWh
  solarTariffRate   Float?
  dgTariffRate      Float?
  contractDemand    Float?    // kVA
  powerFactorTarget Float?
  baselineYear      Int?
  baselineMonth     Int?
  enabledAddons  String   @default("[]") // JSON array of enabled add-on codes: ["KITCHEN"]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clientAccess       ClientAccess[]
  energySources      EnergySource[]
  consumptionEntries ConsumptionEntry[]
  trainingPrograms   TrainingProgram[]
  audits             Audit[]
  capas              CAPA[]
  auditLogs          AuditLog[]
  appSettings        AppSetting[]
  // Phase 2
  clientFrameworks   ClientFramework[]
  inspections        Inspection[]
  incidents          Incident[]
  certifications     Certification[]
  utilityBills       UtilityBill[]
  // Phase 3
  savingsMeasures    SavingsMeasure[]
  roiCalculations    ROICalculation[]
  actionPlans        ActionPlan[]
  documents          Document[]
  // Phase 4
  notifications      Notification[]
  shareableViews     ShareableView[]
  governmentSchemes  SchemeApplication[]
  // Phase 5+
  recurringSchedules RecurringSchedule[]
  // Kitchen Intelligence
  kitchen            Kitchen?
  // IoT Metering
  iotGateways        IoTGateway[]
  iotMeters          IoTMeter[]
  meterAlerts        MeterAlert[]
  // Power Quality
  pqEvents           PQEvent[]
  pqSnapshots        PQSnapshot[]
  // Compressed Air
  compressors        Compressor[]
  caReadings         CAReading[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           String       @default("MEMBER") // OWNER, ADMIN, MEMBER
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model ClientAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  role      String   @default("EMPLOYEE") // CLIENT_ADMIN, EMPLOYEE, VIEWER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clientId])
}

// ============================================================
// USER MODEL
// ============================================================

model User {
  id           String   @id @default(cuid())
  employeeId   String?
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("USER") // PLATFORM_ADMIN, USER
  department   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships        Membership[]
  clientAccess       ClientAccess[]
  consumptionEntries ConsumptionEntry[]
  trainingAttendance TrainingAttendance[]
  auditsLed          Audit[]              @relation("AuditLead")
  capasRaised        CAPA[]               @relation("CAPARaisedBy")
  capasAssigned      CAPA[]               @relation("CAPAAssignedTo")
  capaComments       CAPAComment[]
  // Phase 2
  requirementUpdates RequirementStatus[]  @relation("RequirementUpdatedBy")
  inspectionsLed     Inspection[]         @relation("InspectionInspector")
  incidentsReported  Incident[]           @relation("IncidentReporter")
  incidentsClosed    Incident[]           @relation("IncidentCloser")
  utilityBillsEntered UtilityBill[]
  // Phase 3
  savingsMeasuresCreated SavingsMeasure[]  @relation("SavingsCreatedBy")
  roiCalculationsCreated ROICalculation[]  @relation("ROICreatedBy")
  actionPlansCreated     ActionPlan[]      @relation("ActionPlanCreatedBy")
  actionItemsAssigned    ActionItem[]      @relation("ActionItemAssignee")
  documentsUploaded      Document[]        @relation("DocumentUploadedBy")
  // Phase 4
  notifications          Notification[]    @relation("NotificationRecipient")
  schemeApplications     SchemeApplication[] @relation("SchemeApplicant")
  // Phase 5+
  schedulesAssigned      RecurringSchedule[] @relation("ScheduleAssignee")
  schedulesCreated       RecurringSchedule[] @relation("ScheduleCreator")
}

// ============================================================
// ENERGY MANAGEMENT MODELS (client-scoped)
// ============================================================

model EnergySource {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  name        String
  type        String
  unit        String
  description String?
  location    String?
  meterNumber String?
  costPerUnit Float?   // ₹/kWh — overrides client-level tariff
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  targets            EnergyTarget[]
  consumptionEntries ConsumptionEntry[]
  savingsMeasures    SavingsMeasure[]
  iotMeters          IoTMeter[]
}

model EnergyTarget {
  id               String       @id @default(cuid())
  energySourceId   String
  energySource     EnergySource @relation(fields: [energySourceId], references: [id])
  period           String
  periodType       String
  targetValue      Float
  unit             String
  baselineValue    Float?
  reductionPercent Float?
  actualValue      Float?
  costTarget       Float?       // ₹ target for this period
  isActive         Boolean      @default(true)
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([energySourceId, period])
}

model ConsumptionEntry {
  id               String       @id @default(cuid())
  clientId         String
  client           Client       @relation(fields: [clientId], references: [id])
  energySourceId   String
  energySource     EnergySource @relation(fields: [energySourceId], references: [id])
  recordedById     String
  recordedBy       User         @relation(fields: [recordedById], references: [id])
  date             DateTime
  value            Float
  unit             String
  cost             Float?       // ₹ — auto-calculated from value * costPerUnit
  meterReading     Float?
  previousReading  Float?
  shift            String?
  notes            String?
  hasDeviation      Boolean      @default(false)
  deviationPercent  Float?
  deviationSeverity String?
  deviationNote     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

// ============================================================
// TRAINING MODELS (client-scoped)
// ============================================================

model TrainingProgram {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  title           String
  description     String?
  type            String
  trainer         String?
  scheduledDate   DateTime
  duration        Float?
  location        String?
  maxParticipants Int?
  materialsUrl    String?
  status          String    @default("SCHEDULED")
  completionDate  DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  attendance TrainingAttendance[]
}

model TrainingAttendance {
  id                String          @id @default(cuid())
  trainingProgramId String
  trainingProgram   TrainingProgram @relation(fields: [trainingProgramId], references: [id])
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  attended          Boolean         @default(false)
  score             Float?
  feedback          String?
  certificateIssued Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([trainingProgramId, userId])
}

// ============================================================
// AUDIT MODELS (client-scoped)
// ============================================================

model Audit {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  title           String
  type            String
  auditDate       DateTime
  leadAuditorId   String?
  leadAuditor     User?     @relation("AuditLead", fields: [leadAuditorId], references: [id])
  externalAuditor String?
  scope           String?
  status          String    @default("PLANNED")
  summary         String?
  completedDate   DateTime?
  nextAuditDate   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  findings AuditFinding[]
}

model AuditFinding {
  id             String    @id @default(cuid())
  auditId        String
  audit          Audit     @relation(fields: [auditId], references: [id])
  findingNumber  Int
  category       String
  area           String?
  description    String
  evidence       String?
  recommendation String?
  status         String    @default("OPEN")
  dueDate        DateTime?
  closedDate     DateTime?
  capaId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// CAPA MODELS (client-scoped)
// ============================================================

model CAPA {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  capaNumber      String    @unique
  type            String
  source          String
  sourceReference String?
  title           String
  description     String
  raisedById      String
  raisedBy        User      @relation("CAPARaisedBy", fields: [raisedById], references: [id])
  assignedToId    String?
  assignedTo      User?     @relation("CAPAAssignedTo", fields: [assignedToId], references: [id])
  priority        String    @default("MEDIUM")
  status          String    @default("OPEN")

  rcaMethod        String?
  rcaDetails       String?
  rootCause        String?

  correctiveAction    String?
  preventiveAction    String?
  actionDueDate       DateTime?
  actionCompletedDate DateTime?

  verificationMethod String?
  verificationDate   DateTime?
  verificationResult String?
  verifiedBy         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments CAPAComment[]
}

model CAPAComment {
  id        String   @id @default(cuid())
  capaId    String
  capa      CAPA     @relation(fields: [capaId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  comment   String
  createdAt DateTime @default(now())
}

// ============================================================
// SYSTEM MODELS
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  userId    String?
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
}

model AppSetting {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([clientId, key])
}

// ============================================================
// COMPLIANCE FRAMEWORK MODELS (Phase 2A)
// ============================================================

model ComplianceFramework {
  id             String   @id @default(cuid())
  code           String   @unique // ZED_BRONZE, ISO_50001, ELECTRICAL_SAFETY
  name           String
  description    String?
  version        String   @default("1.0")
  isBuiltIn      Boolean  @default(false) // true = system templates
  organizationId String?  // null for built-in; org-specific for custom
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  requirements    FrameworkRequirement[]
  clientFrameworks ClientFramework[]
}

model FrameworkRequirement {
  id               String              @id @default(cuid())
  frameworkId       String
  framework        ComplianceFramework @relation(fields: [frameworkId], references: [id])
  code             String              // e.g., "ZED-E1", "ISO-4.1"
  category         String              // e.g., "Energy Management", "Leadership"
  title            String
  description      String?
  evidenceGuidance String?             // What evidence is needed
  evidenceModule   String?             // Linked module: ENERGY_SOURCE, CONSUMPTION, TRAINING, AUDIT, CAPA, INSPECTION
  weight           Float               @default(1.0) // Scoring weight
  sortOrder        Int                 @default(0)
  isCritical       Boolean             @default(false) // Must-pass requirement
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  statuses RequirementStatus[]
}

model ClientFramework {
  id            String              @id @default(cuid())
  clientId      String
  client        Client              @relation(fields: [clientId], references: [id])
  frameworkId   String
  framework     ComplianceFramework @relation(fields: [frameworkId], references: [id])
  status        String              @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  assignedDate  DateTime            @default(now())
  targetDate    DateTime?
  score         Float?              // Auto-calculated compliance score (0-100)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  requirementStatuses RequirementStatus[]
  actionPlans         ActionPlan[]

  @@unique([clientId, frameworkId])
}

model RequirementStatus {
  id                  String               @id @default(cuid())
  clientFrameworkId   String
  clientFramework     ClientFramework      @relation(fields: [clientFrameworkId], references: [id])
  requirementId       String
  requirement         FrameworkRequirement @relation(fields: [requirementId], references: [id])
  status              String               @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLIANT, NON_COMPLIANT, NOT_APPLICABLE
  notes               String?
  evidenceLinks       String?              // JSON array of { type, id, label } for linked evidence
  lastReviewedAt      DateTime?
  updatedById         String?
  updatedBy           User?                @relation("RequirementUpdatedBy", fields: [updatedById], references: [id])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([clientFrameworkId, requirementId])
}

// ============================================================
// SAFETY MODELS (Phase 2B)
// ============================================================

model InspectionTemplate {
  id             String   @id @default(cuid())
  name           String
  category       String   // ELECTRICAL, FIRE, GENERAL_SAFETY, CUSTOM
  description    String?
  isBuiltIn      Boolean  @default(false)
  organizationId String?  // null for built-in; org-specific for custom
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items       InspectionTemplateItem[]
  inspections Inspection[]
}

model InspectionTemplateItem {
  id          String             @id @default(cuid())
  templateId  String
  template    InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  section     String             // Group heading
  itemText    String             // The inspection question/check
  helpText    String?            // Guidance for inspector
  type        String             @default("PASS_FAIL") // PASS_FAIL, TEXT, NUMERIC, PHOTO
  isCritical  Boolean            @default(false)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())

  responses InspectionResponse[]
}

model Inspection {
  id              String             @id @default(cuid())
  clientId        String
  client          Client             @relation(fields: [clientId], references: [id])
  templateId      String
  template        InspectionTemplate @relation(fields: [templateId], references: [id])
  inspectorId     String
  inspector       User               @relation("InspectionInspector", fields: [inspectorId], references: [id])
  inspectionDate  DateTime
  location        String?
  status          String             @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED
  overallResult   String?            // PASS, FAIL, PARTIAL
  overallNotes    String?
  score           Float?             // Percentage of items passed
  completedDate   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  responses InspectionResponse[]
}

model InspectionResponse {
  id           String                 @id @default(cuid())
  inspectionId String
  inspection   Inspection             @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  itemId       String
  item         InspectionTemplateItem @relation(fields: [itemId], references: [id])
  result       String?                // PASS, FAIL, NA, or text/numeric value
  notes        String?
  photoUrl     String?
  correctiveActionRequired Boolean    @default(false)
  correctiveActionNotes    String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model Incident {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  type            String    // ELECTRICAL, FIRE, MECHANICAL, CHEMICAL, SLIP_FALL, OTHER
  severity        String    // NEAR_MISS, MINOR, MAJOR, FATAL
  title           String
  description     String
  location        String?
  incidentDate    DateTime
  reportedById    String
  reportedBy      User      @relation("IncidentReporter", fields: [reportedById], references: [id])
  immediateAction String?
  rootCause       String?
  correctiveAction String?
  preventiveAction String?
  status          String    @default("OPEN") // OPEN, INVESTIGATING, CORRECTIVE_ACTION, CLOSED
  closedDate      DateTime?
  closedById      String?
  closedBy        User?     @relation("IncidentCloser", fields: [closedById], references: [id])
  followUpDate    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Certification {
  id                String    @id @default(cuid())
  clientId          String
  client            Client    @relation(fields: [clientId], references: [id])
  name              String    // e.g., "CEIG Electrical Safety Audit", "BIS Pressure Vessel"
  category          String    // ELECTRICAL, FIRE, EQUIPMENT, ENVIRONMENTAL, PERSONNEL, OTHER
  issuingBody       String?   // e.g., "CEIG Karnataka", "BIS"
  certificateNumber String?
  holderId          String?   // User ID if personnel cert; null if equipment/facility cert
  equipmentName     String?   // Equipment name if equipment cert
  issueDate         DateTime?
  expiryDate        DateTime?
  renewalFrequency  String?   // ANNUAL, BIENNIAL, TRIENNIAL, FIVE_YEAR, CUSTOM
  reminderDays      Int       @default(30) // Days before expiry to alert
  status            String    @default("VALID") // VALID, EXPIRING_SOON, EXPIRED, RENEWED
  documentUrl       String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ============================================================
// UTILITY BILL MODEL (Phase 2C)
// ============================================================

model UtilityBill {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id])
  month            Int      // 1-12
  year             Int
  provider         String?  // BESCOM, CESC, MESCOM, etc.
  tariffCategory   String?  // LT, HT, INDUSTRIAL, COMMERCIAL
  // Consumption
  unitsConsumed    Float    // kWh
  demandKVA        Float?   // Recorded demand
  powerFactor      Float?   // 0-1
  // Charges breakdown
  energyCharges    Float?   // ₹
  demandCharges    Float?   // ₹
  pfPenalty        Float?   // ₹ — power factor penalty/surcharge
  pfIncentive      Float?   // ₹ — power factor incentive (if PF > target)
  fuelSurcharge    Float?   // ₹
  electricityDuty  Float?   // ₹
  otherCharges     Float?   // ₹
  totalAmount      Float    // ₹ — total bill amount
  // Meter
  meterReadingStart Float?
  meterReadingEnd   Float?
  isEstimated      Boolean  @default(false) // Was this an estimated bill?
  // Flags (auto-calculated)
  hasPfPenalty     Boolean  @default(false)
  hasDemandOvershoot Boolean @default(false)
  hasAnomaly       Boolean  @default(false)
  anomalyNote      String?
  // Metadata
  notes            String?
  enteredById      String
  enteredBy        User     @relation(fields: [enteredById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([clientId, year, month])
}

// ============================================================
// SAVINGS TRACKER (Phase 3A)
// ============================================================

model SavingsMeasure {
  id                    String    @id @default(cuid())
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id])
  name                  String    // e.g., "VFD on CNC Machine #3"
  description           String?
  category              String    // SOLAR, VFD, LED, POWER_FACTOR, COMPRESSED_AIR, MOTOR, TRANSFORMER, HVAC, PROCESS, OTHER
  energySourceId        String?   // Linked energy source
  energySource          EnergySource? @relation(fields: [energySourceId], references: [id])
  investmentCost        Float     // ₹
  implementationDate    DateTime
  status                String    @default("PLANNED") // PLANNED, IMPLEMENTED, VERIFIED
  estimatedMonthlySavings Float?  // ₹/month expected
  actualMonthlySavings  Float?    // ₹/month measured (auto or manual)
  estimatedKwhSavings   Float?    // kWh/month expected
  actualKwhSavings      Float?    // kWh/month measured
  paybackMonths         Float?    // Auto-calculated: investmentCost / actualMonthlySavings
  cumulativeSavings     Float?    // Running total of actual savings
  notes                 String?
  createdById           String
  createdBy             User      @relation("SavingsCreatedBy", fields: [createdById], references: [id])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  entries SavingsEntry[]
}

model SavingsEntry {
  id              String         @id @default(cuid())
  measureId       String
  measure         SavingsMeasure @relation(fields: [measureId], references: [id], onDelete: Cascade)
  month           Int            // 1-12
  year            Int
  savingsAmount   Float          // ₹ saved this month
  kwhSaved        Float?         // kWh saved this month
  method          String         @default("MANUAL") // MANUAL, CALCULATED (from consumption comparison)
  notes           String?
  createdAt       DateTime       @default(now())

  @@unique([measureId, year, month])
}

// ============================================================
// ROI CALCULATOR (Phase 3B)
// ============================================================

model ROICalculation {
  id                  String   @id @default(cuid())
  clientId            String
  client              Client   @relation(fields: [clientId], references: [id])
  name                String   // e.g., "Solar Rooftop 50kW"
  templateType        String   // SOLAR, VFD, LED, POWER_FACTOR, COMPRESSED_AIR, MOTOR, TRANSFORMER, CUSTOM
  // Inputs (JSON for flexibility — different templates have different inputs)
  inputs              String   // JSON: { systemSizeKW, tariffRate, subsidyPercent, ... }
  // Calculated outputs
  investmentCost      Float    // ₹
  subsidyAmount       Float?   // ₹
  netInvestment       Float    // ₹ (after subsidy)
  monthlySavings      Float    // ₹/month
  annualSavings       Float    // ₹/year
  paybackMonths       Float    // months
  fiveYearSavings     Float?   // ₹
  tenYearSavings      Float?   // ₹
  lifetimeSavings     Float?   // ₹
  irr                 Float?   // % Internal Rate of Return
  npv                 Float?   // ₹ Net Present Value
  co2ReductionKg      Float?   // kg CO2/year
  // Status
  status              String   @default("DRAFT") // DRAFT, SHARED, APPROVED, CONVERTED (→ SavingsMeasure)
  savingsMeasureId    String?  // If converted to actual savings tracking
  createdById         String
  createdBy           User     @relation("ROICreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ============================================================
// ACTION PLANS (Phase 3C)
// ============================================================

model ActionPlan {
  id                  String           @id @default(cuid())
  clientId            String
  client              Client           @relation(fields: [clientId], references: [id])
  clientFrameworkId   String?
  clientFramework     ClientFramework? @relation(fields: [clientFrameworkId], references: [id])
  title               String
  description         String?
  targetDate          DateTime?
  status              String           @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  createdById         String
  createdBy           User             @relation("ActionPlanCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  items ActionItem[]
}

model ActionItem {
  id              String      @id @default(cuid())
  actionPlanId    String
  actionPlan      ActionPlan  @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  assigneeId      String?
  assignee        User?       @relation("ActionItemAssignee", fields: [assigneeId], references: [id])
  dueDate         DateTime?
  status          String      @default("PENDING") // PENDING, IN_PROGRESS, DONE, BLOCKED
  priority        String      @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  sortOrder       Int         @default(0)
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ============================================================
// DOCUMENT LIBRARY (Phase 3C)
// ============================================================

model Document {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  name            String
  category        String   // POLICY, CERTIFICATE, AUDIT_REPORT, TEST_REPORT, PHOTO, BILL, TRAINING_MATERIAL, OTHER
  fileUrl         String   // Vercel Blob URL or external URL
  fileSize        Int?     // bytes
  mimeType        String?
  linkedToType    String?  // AUDIT, TRAINING, INSPECTION, CAPA, CERTIFICATION, SAVINGS_MEASURE, ACTION_PLAN
  linkedToId      String?  // ID of the linked entity
  description     String?
  uploadedById    String
  uploadedBy      User     @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// NOTIFICATIONS (Phase 4A)
// ============================================================

model Notification {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  userId      String    // Recipient
  user        User      @relation("NotificationRecipient", fields: [userId], references: [id])
  type        String    // CERT_EXPIRY, AUDIT_DUE, CAPA_OVERDUE, BILL_ANOMALY, SAFETY_RISK, INSPECTION_DUE, ACTION_OVERDUE, SYSTEM
  title       String
  message     String
  severity    String    @default("INFO") // INFO, WARNING, CRITICAL
  isRead      Boolean   @default(false)
  actionUrl   String?   // Deep link to relevant page
  entityType  String?   // The entity this notification relates to
  entityId    String?
  createdAt   DateTime  @default(now())
}

// ============================================================
// GOVERNMENT SCHEMES & SUBSIDIES (Phase 4C)
// ============================================================

model GovernmentScheme {
  id              String   @id @default(cuid())
  name            String   // e.g., "ZED Certification Subsidy"
  shortName       String?  // e.g., "ZED"
  ministry        String?  // e.g., "MSME Ministry"
  description     String
  maxSubsidy      Float?   // ₹ maximum
  subsidyPercent  Float?   // % of cost
  eligibility     String?  // JSON: { industry, size, state, certifications }
  documentsNeeded String?  // Comma-separated list
  applicationUrl  String?  // Government portal link
  deadline        DateTime?
  isActive        Boolean  @default(true)
  category        String   // ENERGY, CERTIFICATION, EQUIPMENT, SKILL_DEVELOPMENT, GENERAL
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  applications SchemeApplication[]
}

model SchemeApplication {
  id              String           @id @default(cuid())
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id])
  schemeId        String
  scheme          GovernmentScheme @relation(fields: [schemeId], references: [id])
  appliedById     String
  appliedBy       User             @relation("SchemeApplicant", fields: [appliedById], references: [id])
  applicationDate DateTime         @default(now())
  applicationRef  String?          // Government reference number
  status          String           @default("IDENTIFIED") // IDENTIFIED, DOCUMENTS_READY, APPLIED, UNDER_REVIEW, APPROVED, DISBURSED, REJECTED
  amountApplied   Float?           // ₹
  amountApproved  Float?           // ₹
  amountDisbursed Float?           // ₹
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([clientId, schemeId])
}

// ============================================================
// SHAREABLE VIEWS (Phase 4D — Vendor Qualification)
// ============================================================

model ShareableView {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  token       String    @unique // Random token for public URL
  title       String    @default("Compliance Dashboard")
  sections    String?   // JSON: which sections to show (compliance, certifications, safety, etc.)
  isActive    Boolean   @default(true)
  expiresAt   DateTime? // Optional expiry
  viewCount   Int       @default(0)
  lastViewedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Recurring Schedule — generates calendar events and reminder notifications
model RecurringSchedule {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  title       String
  description String?
  category    String    // INSPECTION, TRAINING, AUDIT, CERTIFICATION_RENEWAL, DATA_ENTRY, CUSTOM
  frequency   String    // DAILY, WEEKLY, BIWEEKLY, MONTHLY, QUARTERLY, BIANNUAL, ANNUAL
  dayOfMonth  Int?      // For MONTHLY/QUARTERLY: which day (1-28)
  dayOfWeek   Int?      // For WEEKLY/BIWEEKLY: 0=Sun..6=Sat
  monthOfYear Int?      // For ANNUAL/BIANNUAL: which month (1-12)
  startDate   DateTime
  endDate     DateTime? // Optional end date
  reminderDays Int      @default(7) // Days before to send reminder
  assignedToId String?
  assignedTo   User?    @relation("ScheduleAssignee", fields: [assignedToId], references: [id])
  createdById  String?
  createdBy    User?    @relation("ScheduleCreator", fields: [createdById], references: [id])
  lastTriggered DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================================
// KITCHEN INTELLIGENCE MODULE
// ============================================================

model Kitchen {
  id                     String   @id @default(cuid())
  clientId               String   @unique
  client                 Client   @relation(fields: [clientId], references: [id])
  name                   String
  address                String?
  discomCode             String   // BESCOM, MSEDCL, TNEB, KSEB, TSSPDCL, CESC, OTHER
  connectionType         String   @default("LT_COMMERCIAL") // LT_COMMERCIAL, HT
  contractedDemandKVA    Float
  sanctionedLoadKW       Float?
  // Tariff config
  demandChargePerKVA     Float?   // ₹/kVA/month
  mdPenaltyMultiplier    Float    @default(2.0) // 2× rate for excess demand
  pfTarget               Float    @default(0.90)
  pfPenaltyRatePercent   Float?   // % surcharge per 0.01 below target
  pfIncentiveRatePercent Float?   // % incentive per 0.01 above target
  tariffRatePerKwh       Float?   // base ₹/kWh
  todSlabsJson           String?  // JSON: [{name, startHour, endHour, rateMultiplier}]
  billingCycleDay        Int      @default(1)
  // Thresholds
  warningThresholdPct    Float    @default(80)  // demand warning at 80% of CD
  criticalThresholdPct   Float    @default(92)  // demand critical at 92% of CD
  // Load management
  autoShedEnabled        Boolean  @default(false)
  shedTier3AtPct         Float    @default(80)  // shed tier 3 zones at this %
  shedTier2AtPct         Float    @default(92)  // shed tier 2 zones at this %
  restoreBelowPct        Float    @default(75)  // restore zones when demand drops below
  // Status
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  zones            KitchenZone[]
  titanReadings    TitanReading[]
  demandEvents     DemandEvent[]
  monthlySummaries MonthlyKitchenSummary[]
  apiKeys          KitchenApiKey[]
}

model KitchenZone {
  id             String   @id @default(cuid())
  kitchenId      String
  kitchen        Kitchen  @relation(fields: [kitchenId], references: [id])
  name           String   // e.g., "Burner 1", "Tawa Station", "Stock Pot"
  zoneType       String   @default("OTHER") // BURNER, TAWA, FRYER, STOCK_POT, WARMER, UTILITY, CNC, COMPRESSOR, OTHER
  meterId        String?  // Titan meter ID mapped to this zone
  titanDoChannel Int?     // 1 or 2 — Titan digital output channel for load control
  priorityTier   Int      @default(2) // 1=never shed, 2=shed if critical, 3=shed at warning
  maxLoadKW      Float?   // rated max power
  // HACCP
  haccpEnabled   Boolean  @default(false)
  haccpAiChannel Int?     // Titan analog input channel for temp probe
  targetTempC    Float?
  minTempC       Float?
  maxTempC       Float?
  // Status
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  titanReadings TitanReading[]
}

model TitanReading {
  id          String    @id @default(cuid())
  kitchenId   String
  kitchen     Kitchen   @relation(fields: [kitchenId], references: [id])
  zoneId      String?
  zone        KitchenZone? @relation(fields: [zoneId], references: [id])
  meterId     String
  timestamp   DateTime
  // Electrical
  activePowerKW     Float
  apparentPowerKVA  Float?
  reactivePowerKVAR Float?
  powerFactor       Float?
  voltageR          Float?
  voltageY          Float?
  voltageB          Float?
  currentR          Float?
  currentY          Float?
  currentB          Float?
  frequencyHz       Float?
  energyKwh         Float?  // cumulative meter reading
  demandMaxKVA      Float?  // cumulative max demand from meter
  demandCurrentKVA  Float?  // instantaneous demand
  thdVoltage        Float?
  thdCurrent        Float?
  // I/O
  ai1Value    Float?   // analog input 1 (temperature)
  ai2Value    Float?   // analog input 2
  do1State    Boolean? // digital output 1 state
  do2State    Boolean? // digital output 2 state
  // Meta
  createdAt   DateTime @default(now())

  @@index([kitchenId, timestamp])
  @@index([meterId, timestamp])
}

model DemandEvent {
  id                   String    @id @default(cuid())
  kitchenId            String
  kitchen              Kitchen   @relation(fields: [kitchenId], references: [id])
  type                 String    // WARNING, CRITICAL, BREACH, SHED_INITIATED, SHED_RELEASED, PF_ALERT, METER_OFFLINE
  severity             String    @default("WARNING") // INFO, WARNING, CRITICAL
  demandKVA            Float?
  thresholdKVA         Float?
  contractedDemandKVA  Float?
  pf                   Float?
  message              String
  zonesAffectedJson    String?   // JSON array of zone names/IDs
  resolvedAt           DateTime?
  createdAt            DateTime  @default(now())

  @@index([kitchenId, createdAt])
}

model MonthlyKitchenSummary {
  id                   String  @id @default(cuid())
  kitchenId            String
  kitchen              Kitchen @relation(fields: [kitchenId], references: [id])
  year                 Int
  month                Int
  totalKwh             Float
  peakDemandKVA        Float
  avgPf                Float?
  demandWarnings       Int     @default(0)
  demandBreaches       Int     @default(0)
  estimatedBillAmount  Float?
  mdPenaltyAmount      Float?
  mdPenaltiesAvoided   Float?
  pfPenaltyAmount      Float?
  pfIncentiveAmount    Float?
  todPeakKwh           Float?
  todOffPeakKwh        Float?
  todSavingsAmount     Float?
  totalSavings         Float?
  haccpComplianceRate  Float?
  loadShedEvents       Int     @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([kitchenId, year, month])
}

model KitchenApiKey {
  id          String    @id @default(cuid())
  kitchenId   String
  kitchen     Kitchen   @relation(fields: [kitchenId], references: [id])
  keyHash     String    // bcrypt hash of the full API key
  keyPrefix   String    // first 8 chars for identification
  name        String    // descriptive label
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================================
// IOT METERING MODULE
// ============================================================

model IoTGateway {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  name            String                          // e.g., "Main Panel Gateway"
  serialNumber    String?                         // physical device serial
  gatewayType     String   @default("ESX_UNIVERSAL") // ESX_UNIVERSAL, PAS600, RASPBERRY_PI, INDUSTRIAL_PC, OTHER
  make            String?                         // SCHNEIDER, LOTUS, OTHER
  firmwareVersion String?
  ipAddress       String?                         // local network IP
  location        String?                         // physical location description
  // MQTT config
  mqttBrokerUrl   String?                         // e.g., mqtts://broker.hivemq.com:8883
  mqttTopicPrefix String?                         // e.g., voltspark/{clientId}/site1
  mqttClientId    String?                         // MQTT client ID for this gateway
  // Push config
  pushIntervalSeconds Int  @default(60)           // how often gateway pushes data
  protocol        String   @default("MQTT_WEBHOOK") // REST, MQTT_WEBHOOK, MQTT_DIRECT
  // Status
  isOnline        Boolean  @default(false)
  lastSeenAt      DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  meters          IoTMeter[]
  apiKeys         IoTApiKey[]

  @@index([clientId])
}

model IoTMeter {
  id             String       @id @default(cuid())
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  gatewayId      String
  gateway        IoTGateway   @relation(fields: [gatewayId], references: [id])
  energySourceId String?
  energySource   EnergySource? @relation(fields: [energySourceId], references: [id])
  // Meter identity
  name           String                          // e.g., "Incomer Meter", "Compressor Panel"
  meterSerial    String?                         // physical meter serial number
  modbusAddress  Int?                            // Modbus slave address (1-247)
  make           String?                         // SCHNEIDER, ABB, SIEMENS, SECURE, ELMEASURE, OTHER
  model          String?                         // EM6400NG+, EM7230, ION9000, PM8000, etc.
  meterType      String   @default("SUBMETER")   // INCOMER, SUBMETER, DG, SOLAR, OTHER
  // Measurement config
  ctRatio        Float?                          // CT ratio (e.g., 200 for 200/5A CT)
  ptRatio        Float?                          // PT ratio (if applicable)
  ratedVoltage   Float?                          // nominal voltage (415V, 11kV, etc.)
  // Thresholds for alerts
  demandWarningPct  Float?  @default(80)         // % of contracted demand for warning
  demandCriticalPct Float?  @default(92)         // % of contracted demand for critical
  pfLowThreshold    Float?  @default(0.85)       // PF below this triggers alert
  // Location
  panelName      String?                         // which panel this meter is in
  circuitName    String?                         // which circuit/feeder
  location       String?
  // Status
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  readings         MeterReading[]
  alerts           MeterAlert[]
  monthlySummaries IoTMonthlySummary[]
  pqEvents         PQEvent[]
  pqSnapshots      PQSnapshot[]
  compressors      Compressor[]

  @@index([clientId])
  @@index([gatewayId])
}

model MeterReading {
  id                String   @id @default(cuid())
  meterId           String
  meter             IoTMeter @relation(fields: [meterId], references: [id])
  timestamp         DateTime
  // Power
  activePowerKW     Float
  apparentPowerKVA  Float?
  reactivePowerKVAR Float?
  powerFactor       Float?
  // Voltage (per phase)
  voltageR          Float?
  voltageY          Float?
  voltageB          Float?
  voltageAvg        Float?
  // Current (per phase)
  currentR          Float?
  currentY          Float?
  currentB          Float?
  currentAvg        Float?
  // Energy (cumulative from meter)
  energyKwh         Float?     // cumulative active energy import
  energyKwhExport   Float?     // cumulative active energy export (solar)
  energyKvarhImport Float?     // cumulative reactive energy import
  energyKvarhExport Float?     // cumulative reactive energy export
  // Demand
  demandKW          Float?     // current demand
  demandKVA         Float?     // current apparent demand
  maxDemandKW       Float?     // max demand since last reset
  maxDemandKVA      Float?     // max apparent demand since last reset
  // Quality
  frequencyHz       Float?
  thdVoltage        Float?     // total harmonic distortion - voltage %
  thdCurrent        Float?     // total harmonic distortion - current %
  voltageUnbalance  Float?     // % unbalance
  currentUnbalance  Float?     // % unbalance
  // Vendor-specific extra data
  extraDataJson     String?    // JSON for fields not in standard schema
  createdAt         DateTime   @default(now())

  @@index([meterId, timestamp])
  @@index([timestamp])
}

model IoTApiKey {
  id          String     @id @default(cuid())
  gatewayId   String
  gateway     IoTGateway @relation(fields: [gatewayId], references: [id])
  keyHash     String     // full key stored (MVP); upgrade to bcrypt later
  keyPrefix   String     // first 12 chars for lookup (vsi_ + 8 chars)
  name        String     // descriptive label
  isActive    Boolean    @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model MeterAlert {
  id               String    @id @default(cuid())
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id])
  meterId          String?
  meter            IoTMeter? @relation(fields: [meterId], references: [id])
  type             String    // DEMAND_WARNING, DEMAND_CRITICAL, DEMAND_BREACH, PF_LOW, VOLTAGE_SAG, VOLTAGE_SWELL, THD_HIGH, METER_OFFLINE, GATEWAY_OFFLINE
  severity         String    @default("WARNING") // INFO, WARNING, CRITICAL
  parameterName    String?   // which parameter triggered: demandKVA, powerFactor, voltageR, etc.
  actualValue      Float?
  thresholdValue   Float?
  message          String
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())

  @@index([clientId, createdAt])
  @@index([meterId, createdAt])
}

model IoTMonthlySummary {
  id              String   @id @default(cuid())
  meterId         String
  meter           IoTMeter @relation(fields: [meterId], references: [id])
  year            Int
  month           Int
  totalKwh        Float
  peakDemandKW    Float?
  peakDemandKVA   Float?
  avgPowerFactor  Float?
  minVoltage      Float?
  maxVoltage      Float?
  avgFrequency    Float?
  alertCount      Int      @default(0)
  readingCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([meterId, year, month])
}

// ============================================================
// COMPRESSED AIR INTELLIGENCE MODULE
// ============================================================

model Compressor {
  id                String   @id @default(cuid())
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id])
  meterId           String?
  meter             IoTMeter? @relation(fields: [meterId], references: [id])
  name              String     // e.g., "Compressor 1 — Atlas Copco GA75"
  make              String?    // ATLAS_COPCO, INGERSOLL_RAND, KAESER, ELGI, CHICAGO_PNEUMATIC, OTHER
  model             String?
  type              String     @default("SCREW") // SCREW, RECIPROCATING, CENTRIFUGAL, SCROLL
  ratedPowerKW      Float?     // nameplate power (kW)
  ratedFlowM3Min    Float?     // rated free air delivery (m³/min or CFM)
  ratedPressureBar  Float?     // rated discharge pressure (bar)
  motorEfficiency   Float?     // motor efficiency (0-1)
  isVSD             Boolean    @default(false) // Variable Speed Drive equipped
  location          String?
  commissionedDate  DateTime?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  readings          CAReading[]

  @@index([clientId])
}

model CAReading {
  id                String     @id @default(cuid())
  clientId          String
  client            Client     @relation(fields: [clientId], references: [id])
  compressorId      String
  compressor        Compressor @relation(fields: [compressorId], references: [id])
  date              DateTime
  // Energy
  energyKwh         Float      // kWh consumed in this period
  runHours          Float?     // compressor run hours
  loadHours         Float?     // hours under load (vs unload/idle)
  // Air output
  airFlowM3         Float?     // total compressed air produced (m³)
  avgPressureBar    Float?     // average discharge pressure
  // Calculated metrics
  specificEnergy    Float?     // kWh/m³ (auto-calculated)
  loadPercent       Float?     // loadHours/runHours * 100
  // Anomalies
  hasAnomaly        Boolean    @default(false)
  anomalyNote       String?
  notes             String?
  createdAt         DateTime   @default(now())

  @@unique([compressorId, date])
  @@index([clientId, date])
}

// ============================================================
// POWER QUALITY MODULE
// ============================================================

model PQEvent {
  id               String    @id @default(cuid())
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id])
  meterId          String
  meter            IoTMeter  @relation(fields: [meterId], references: [id])
  type             String    // VOLTAGE_SAG, VOLTAGE_SWELL, THD_V_HIGH, THD_I_HIGH, PF_LOW, VOLTAGE_UNBALANCE, FREQUENCY_DEVIATION
  severity         String    @default("WARNING") // INFO, WARNING, CRITICAL
  phase            String?   // R, Y, B, ALL
  actualValue      Float
  thresholdValue   Float
  nominalValue     Float?    // reference value (e.g., 415V nominal)
  durationMs       Int?      // event duration in milliseconds (for sags/swells)
  message          String
  readingId        String?   // reference to MeterReading that triggered this
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())

  @@index([clientId, createdAt])
  @@index([meterId, createdAt])
  @@index([type, createdAt])
}

model PQSnapshot {
  id                 String   @id @default(cuid())
  clientId           String
  client             Client   @relation(fields: [clientId], references: [id])
  meterId            String
  meter              IoTMeter @relation(fields: [meterId], references: [id])
  date               DateTime // snapshot date (daily)
  // Voltage stats
  voltageAvgMin      Float?
  voltageAvgMax      Float?
  voltageAvgMean     Float?
  voltageSagCount    Int      @default(0)
  voltageSwellCount  Int      @default(0)
  voltageUnbalanceMax Float?
  // THD stats
  thdVoltageMax      Float?
  thdVoltageMean     Float?
  thdCurrentMax      Float?
  thdCurrentMean     Float?
  thdExceedanceCount Int      @default(0) // readings where THD > threshold
  // Power factor
  pfMin              Float?
  pfMean             Float?
  pfBelowTarget      Int      @default(0) // readings where PF < target
  // Frequency
  freqMin            Float?
  freqMax            Float?
  freqMean           Float?
  // Compliance score (0-100, weighted across EN 50160 criteria)
  complianceScore    Float?
  totalReadings      Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([meterId, date])
  @@index([clientId, date])
}

model DiscomTemplate {
  id                     String   @id @default(cuid())
  code                   String   @unique // e.g., BESCOM_HT_2A
  discomName             String   // e.g., "BESCOM"
  state                  String   // e.g., "Karnataka"
  category               String   // HT, LT, INDUSTRIAL, COMMERCIAL
  tariffRatePerKwh       Float
  demandChargePerKVA     Float?
  pfTarget               Float    @default(0.90)
  pfPenaltyRatePercent   Float?
  pfIncentiveRatePercent Float?
  mdPenaltyMultiplier    Float    @default(2.0)
  todSlabsJson           String?  // JSON: [{name, startHour, endHour, rateMultiplier}]
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
