generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// MULTI-TENANCY MODELS
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  website   String?
  plan      String   @default("FREE") // FREE, PRO, ENTERPRISE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients     Client[]
  memberships Membership[]
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  slug           String       @unique
  address        String?
  industry       String?
  employeeCount  Int?
  accessMode     String       @default("COLLABORATIVE") // CONSULTANT_MANAGED, COLLABORATIVE, SELF_SERVICE
  // Energy cost config
  gridTariffRate    Float?    // ₹/kWh
  solarTariffRate   Float?
  dgTariffRate      Float?
  contractDemand    Float?    // kVA
  powerFactorTarget Float?
  baselineYear      Int?
  baselineMonth     Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clientAccess       ClientAccess[]
  energySources      EnergySource[]
  consumptionEntries ConsumptionEntry[]
  trainingPrograms   TrainingProgram[]
  audits             Audit[]
  capas              CAPA[]
  auditLogs          AuditLog[]
  appSettings        AppSetting[]
  // Phase 2
  clientFrameworks   ClientFramework[]
  inspections        Inspection[]
  incidents          Incident[]
  certifications     Certification[]
  utilityBills       UtilityBill[]
  // Phase 3
  savingsMeasures    SavingsMeasure[]
  roiCalculations    ROICalculation[]
  actionPlans        ActionPlan[]
  documents          Document[]
  // Phase 4
  notifications      Notification[]
  shareableViews     ShareableView[]
  governmentSchemes  SchemeApplication[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           String       @default("MEMBER") // OWNER, ADMIN, MEMBER
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model ClientAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  role      String   @default("EMPLOYEE") // CLIENT_ADMIN, EMPLOYEE, VIEWER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clientId])
}

// ============================================================
// USER MODEL
// ============================================================

model User {
  id           String   @id @default(cuid())
  employeeId   String?
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("USER") // PLATFORM_ADMIN, USER
  department   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships        Membership[]
  clientAccess       ClientAccess[]
  consumptionEntries ConsumptionEntry[]
  trainingAttendance TrainingAttendance[]
  auditsLed          Audit[]              @relation("AuditLead")
  capasRaised        CAPA[]               @relation("CAPARaisedBy")
  capasAssigned      CAPA[]               @relation("CAPAAssignedTo")
  capaComments       CAPAComment[]
  // Phase 2
  requirementUpdates RequirementStatus[]  @relation("RequirementUpdatedBy")
  inspectionsLed     Inspection[]         @relation("InspectionInspector")
  incidentsReported  Incident[]           @relation("IncidentReporter")
  incidentsClosed    Incident[]           @relation("IncidentCloser")
  utilityBillsEntered UtilityBill[]
  // Phase 3
  savingsMeasuresCreated SavingsMeasure[]  @relation("SavingsCreatedBy")
  roiCalculationsCreated ROICalculation[]  @relation("ROICreatedBy")
  actionPlansCreated     ActionPlan[]      @relation("ActionPlanCreatedBy")
  actionItemsAssigned    ActionItem[]      @relation("ActionItemAssignee")
  documentsUploaded      Document[]        @relation("DocumentUploadedBy")
  // Phase 4
  notifications          Notification[]    @relation("NotificationRecipient")
  schemeApplications     SchemeApplication[] @relation("SchemeApplicant")
}

// ============================================================
// ENERGY MANAGEMENT MODELS (client-scoped)
// ============================================================

model EnergySource {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  name        String
  type        String
  unit        String
  description String?
  location    String?
  meterNumber String?
  costPerUnit Float?   // ₹/kWh — overrides client-level tariff
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  targets            EnergyTarget[]
  consumptionEntries ConsumptionEntry[]
  savingsMeasures    SavingsMeasure[]
}

model EnergyTarget {
  id               String       @id @default(cuid())
  energySourceId   String
  energySource     EnergySource @relation(fields: [energySourceId], references: [id])
  period           String
  periodType       String
  targetValue      Float
  unit             String
  baselineValue    Float?
  reductionPercent Float?
  actualValue      Float?
  costTarget       Float?       // ₹ target for this period
  isActive         Boolean      @default(true)
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([energySourceId, period])
}

model ConsumptionEntry {
  id               String       @id @default(cuid())
  clientId         String
  client           Client       @relation(fields: [clientId], references: [id])
  energySourceId   String
  energySource     EnergySource @relation(fields: [energySourceId], references: [id])
  recordedById     String
  recordedBy       User         @relation(fields: [recordedById], references: [id])
  date             DateTime
  value            Float
  unit             String
  cost             Float?       // ₹ — auto-calculated from value * costPerUnit
  meterReading     Float?
  previousReading  Float?
  shift            String?
  notes            String?
  hasDeviation      Boolean      @default(false)
  deviationPercent  Float?
  deviationSeverity String?
  deviationNote     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

// ============================================================
// TRAINING MODELS (client-scoped)
// ============================================================

model TrainingProgram {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  title           String
  description     String?
  type            String
  trainer         String?
  scheduledDate   DateTime
  duration        Float?
  location        String?
  maxParticipants Int?
  materialsUrl    String?
  status          String    @default("SCHEDULED")
  completionDate  DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  attendance TrainingAttendance[]
}

model TrainingAttendance {
  id                String          @id @default(cuid())
  trainingProgramId String
  trainingProgram   TrainingProgram @relation(fields: [trainingProgramId], references: [id])
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  attended          Boolean         @default(false)
  score             Float?
  feedback          String?
  certificateIssued Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([trainingProgramId, userId])
}

// ============================================================
// AUDIT MODELS (client-scoped)
// ============================================================

model Audit {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  title           String
  type            String
  auditDate       DateTime
  leadAuditorId   String?
  leadAuditor     User?     @relation("AuditLead", fields: [leadAuditorId], references: [id])
  externalAuditor String?
  scope           String?
  status          String    @default("PLANNED")
  summary         String?
  completedDate   DateTime?
  nextAuditDate   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  findings AuditFinding[]
}

model AuditFinding {
  id             String    @id @default(cuid())
  auditId        String
  audit          Audit     @relation(fields: [auditId], references: [id])
  findingNumber  Int
  category       String
  area           String?
  description    String
  evidence       String?
  recommendation String?
  status         String    @default("OPEN")
  dueDate        DateTime?
  closedDate     DateTime?
  capaId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// CAPA MODELS (client-scoped)
// ============================================================

model CAPA {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  capaNumber      String    @unique
  type            String
  source          String
  sourceReference String?
  title           String
  description     String
  raisedById      String
  raisedBy        User      @relation("CAPARaisedBy", fields: [raisedById], references: [id])
  assignedToId    String?
  assignedTo      User?     @relation("CAPAAssignedTo", fields: [assignedToId], references: [id])
  priority        String    @default("MEDIUM")
  status          String    @default("OPEN")

  rcaMethod        String?
  rcaDetails       String?
  rootCause        String?

  correctiveAction    String?
  preventiveAction    String?
  actionDueDate       DateTime?
  actionCompletedDate DateTime?

  verificationMethod String?
  verificationDate   DateTime?
  verificationResult String?
  verifiedBy         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments CAPAComment[]
}

model CAPAComment {
  id        String   @id @default(cuid())
  capaId    String
  capa      CAPA     @relation(fields: [capaId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  comment   String
  createdAt DateTime @default(now())
}

// ============================================================
// SYSTEM MODELS
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  userId    String?
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
}

model AppSetting {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([clientId, key])
}

// ============================================================
// COMPLIANCE FRAMEWORK MODELS (Phase 2A)
// ============================================================

model ComplianceFramework {
  id             String   @id @default(cuid())
  code           String   @unique // ZED_BRONZE, ISO_50001, ELECTRICAL_SAFETY
  name           String
  description    String?
  version        String   @default("1.0")
  isBuiltIn      Boolean  @default(false) // true = system templates
  organizationId String?  // null for built-in; org-specific for custom
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  requirements    FrameworkRequirement[]
  clientFrameworks ClientFramework[]
}

model FrameworkRequirement {
  id               String              @id @default(cuid())
  frameworkId       String
  framework        ComplianceFramework @relation(fields: [frameworkId], references: [id])
  code             String              // e.g., "ZED-E1", "ISO-4.1"
  category         String              // e.g., "Energy Management", "Leadership"
  title            String
  description      String?
  evidenceGuidance String?             // What evidence is needed
  evidenceModule   String?             // Linked module: ENERGY_SOURCE, CONSUMPTION, TRAINING, AUDIT, CAPA, INSPECTION
  weight           Float               @default(1.0) // Scoring weight
  sortOrder        Int                 @default(0)
  isCritical       Boolean             @default(false) // Must-pass requirement
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  statuses RequirementStatus[]
}

model ClientFramework {
  id            String              @id @default(cuid())
  clientId      String
  client        Client              @relation(fields: [clientId], references: [id])
  frameworkId   String
  framework     ComplianceFramework @relation(fields: [frameworkId], references: [id])
  status        String              @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  assignedDate  DateTime            @default(now())
  targetDate    DateTime?
  score         Float?              // Auto-calculated compliance score (0-100)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  requirementStatuses RequirementStatus[]
  actionPlans         ActionPlan[]

  @@unique([clientId, frameworkId])
}

model RequirementStatus {
  id                  String               @id @default(cuid())
  clientFrameworkId   String
  clientFramework     ClientFramework      @relation(fields: [clientFrameworkId], references: [id])
  requirementId       String
  requirement         FrameworkRequirement @relation(fields: [requirementId], references: [id])
  status              String               @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLIANT, NON_COMPLIANT, NOT_APPLICABLE
  notes               String?
  evidenceLinks       String?              // JSON array of { type, id, label } for linked evidence
  lastReviewedAt      DateTime?
  updatedById         String?
  updatedBy           User?                @relation("RequirementUpdatedBy", fields: [updatedById], references: [id])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([clientFrameworkId, requirementId])
}

// ============================================================
// SAFETY MODELS (Phase 2B)
// ============================================================

model InspectionTemplate {
  id             String   @id @default(cuid())
  name           String
  category       String   // ELECTRICAL, FIRE, GENERAL_SAFETY, CUSTOM
  description    String?
  isBuiltIn      Boolean  @default(false)
  organizationId String?  // null for built-in; org-specific for custom
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items       InspectionTemplateItem[]
  inspections Inspection[]
}

model InspectionTemplateItem {
  id          String             @id @default(cuid())
  templateId  String
  template    InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  section     String             // Group heading
  itemText    String             // The inspection question/check
  helpText    String?            // Guidance for inspector
  type        String             @default("PASS_FAIL") // PASS_FAIL, TEXT, NUMERIC, PHOTO
  isCritical  Boolean            @default(false)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())

  responses InspectionResponse[]
}

model Inspection {
  id              String             @id @default(cuid())
  clientId        String
  client          Client             @relation(fields: [clientId], references: [id])
  templateId      String
  template        InspectionTemplate @relation(fields: [templateId], references: [id])
  inspectorId     String
  inspector       User               @relation("InspectionInspector", fields: [inspectorId], references: [id])
  inspectionDate  DateTime
  location        String?
  status          String             @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED
  overallResult   String?            // PASS, FAIL, PARTIAL
  overallNotes    String?
  score           Float?             // Percentage of items passed
  completedDate   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  responses InspectionResponse[]
}

model InspectionResponse {
  id           String                 @id @default(cuid())
  inspectionId String
  inspection   Inspection             @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  itemId       String
  item         InspectionTemplateItem @relation(fields: [itemId], references: [id])
  result       String?                // PASS, FAIL, NA, or text/numeric value
  notes        String?
  photoUrl     String?
  correctiveActionRequired Boolean    @default(false)
  correctiveActionNotes    String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model Incident {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  type            String    // ELECTRICAL, FIRE, MECHANICAL, CHEMICAL, SLIP_FALL, OTHER
  severity        String    // NEAR_MISS, MINOR, MAJOR, FATAL
  title           String
  description     String
  location        String?
  incidentDate    DateTime
  reportedById    String
  reportedBy      User      @relation("IncidentReporter", fields: [reportedById], references: [id])
  immediateAction String?
  rootCause       String?
  correctiveAction String?
  preventiveAction String?
  status          String    @default("OPEN") // OPEN, INVESTIGATING, CORRECTIVE_ACTION, CLOSED
  closedDate      DateTime?
  closedById      String?
  closedBy        User?     @relation("IncidentCloser", fields: [closedById], references: [id])
  followUpDate    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Certification {
  id                String    @id @default(cuid())
  clientId          String
  client            Client    @relation(fields: [clientId], references: [id])
  name              String    // e.g., "CEIG Electrical Safety Audit", "BIS Pressure Vessel"
  category          String    // ELECTRICAL, FIRE, EQUIPMENT, ENVIRONMENTAL, PERSONNEL, OTHER
  issuingBody       String?   // e.g., "CEIG Karnataka", "BIS"
  certificateNumber String?
  holderId          String?   // User ID if personnel cert; null if equipment/facility cert
  equipmentName     String?   // Equipment name if equipment cert
  issueDate         DateTime?
  expiryDate        DateTime?
  renewalFrequency  String?   // ANNUAL, BIENNIAL, TRIENNIAL, FIVE_YEAR, CUSTOM
  reminderDays      Int       @default(30) // Days before expiry to alert
  status            String    @default("VALID") // VALID, EXPIRING_SOON, EXPIRED, RENEWED
  documentUrl       String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ============================================================
// UTILITY BILL MODEL (Phase 2C)
// ============================================================

model UtilityBill {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id])
  month            Int      // 1-12
  year             Int
  provider         String?  // BESCOM, CESC, MESCOM, etc.
  tariffCategory   String?  // LT, HT, INDUSTRIAL, COMMERCIAL
  // Consumption
  unitsConsumed    Float    // kWh
  demandKVA        Float?   // Recorded demand
  powerFactor      Float?   // 0-1
  // Charges breakdown
  energyCharges    Float?   // ₹
  demandCharges    Float?   // ₹
  pfPenalty        Float?   // ₹ — power factor penalty/surcharge
  pfIncentive      Float?   // ₹ — power factor incentive (if PF > target)
  fuelSurcharge    Float?   // ₹
  electricityDuty  Float?   // ₹
  otherCharges     Float?   // ₹
  totalAmount      Float    // ₹ — total bill amount
  // Meter
  meterReadingStart Float?
  meterReadingEnd   Float?
  isEstimated      Boolean  @default(false) // Was this an estimated bill?
  // Flags (auto-calculated)
  hasPfPenalty     Boolean  @default(false)
  hasDemandOvershoot Boolean @default(false)
  hasAnomaly       Boolean  @default(false)
  anomalyNote      String?
  // Metadata
  notes            String?
  enteredById      String
  enteredBy        User     @relation(fields: [enteredById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([clientId, year, month])
}

// ============================================================
// SAVINGS TRACKER (Phase 3A)
// ============================================================

model SavingsMeasure {
  id                    String    @id @default(cuid())
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id])
  name                  String    // e.g., "VFD on CNC Machine #3"
  description           String?
  category              String    // SOLAR, VFD, LED, POWER_FACTOR, COMPRESSED_AIR, MOTOR, TRANSFORMER, HVAC, PROCESS, OTHER
  energySourceId        String?   // Linked energy source
  energySource          EnergySource? @relation(fields: [energySourceId], references: [id])
  investmentCost        Float     // ₹
  implementationDate    DateTime
  status                String    @default("PLANNED") // PLANNED, IMPLEMENTED, VERIFIED
  estimatedMonthlySavings Float?  // ₹/month expected
  actualMonthlySavings  Float?    // ₹/month measured (auto or manual)
  estimatedKwhSavings   Float?    // kWh/month expected
  actualKwhSavings      Float?    // kWh/month measured
  paybackMonths         Float?    // Auto-calculated: investmentCost / actualMonthlySavings
  cumulativeSavings     Float?    // Running total of actual savings
  notes                 String?
  createdById           String
  createdBy             User      @relation("SavingsCreatedBy", fields: [createdById], references: [id])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  entries SavingsEntry[]
}

model SavingsEntry {
  id              String         @id @default(cuid())
  measureId       String
  measure         SavingsMeasure @relation(fields: [measureId], references: [id], onDelete: Cascade)
  month           Int            // 1-12
  year            Int
  savingsAmount   Float          // ₹ saved this month
  kwhSaved        Float?         // kWh saved this month
  method          String         @default("MANUAL") // MANUAL, CALCULATED (from consumption comparison)
  notes           String?
  createdAt       DateTime       @default(now())

  @@unique([measureId, year, month])
}

// ============================================================
// ROI CALCULATOR (Phase 3B)
// ============================================================

model ROICalculation {
  id                  String   @id @default(cuid())
  clientId            String
  client              Client   @relation(fields: [clientId], references: [id])
  name                String   // e.g., "Solar Rooftop 50kW"
  templateType        String   // SOLAR, VFD, LED, POWER_FACTOR, COMPRESSED_AIR, MOTOR, TRANSFORMER, CUSTOM
  // Inputs (JSON for flexibility — different templates have different inputs)
  inputs              String   // JSON: { systemSizeKW, tariffRate, subsidyPercent, ... }
  // Calculated outputs
  investmentCost      Float    // ₹
  subsidyAmount       Float?   // ₹
  netInvestment       Float    // ₹ (after subsidy)
  monthlySavings      Float    // ₹/month
  annualSavings       Float    // ₹/year
  paybackMonths       Float    // months
  fiveYearSavings     Float?   // ₹
  tenYearSavings      Float?   // ₹
  lifetimeSavings     Float?   // ₹
  irr                 Float?   // % Internal Rate of Return
  npv                 Float?   // ₹ Net Present Value
  co2ReductionKg      Float?   // kg CO2/year
  // Status
  status              String   @default("DRAFT") // DRAFT, SHARED, APPROVED, CONVERTED (→ SavingsMeasure)
  savingsMeasureId    String?  // If converted to actual savings tracking
  createdById         String
  createdBy           User     @relation("ROICreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ============================================================
// ACTION PLANS (Phase 3C)
// ============================================================

model ActionPlan {
  id                  String           @id @default(cuid())
  clientId            String
  client              Client           @relation(fields: [clientId], references: [id])
  clientFrameworkId   String?
  clientFramework     ClientFramework? @relation(fields: [clientFrameworkId], references: [id])
  title               String
  description         String?
  targetDate          DateTime?
  status              String           @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  createdById         String
  createdBy           User             @relation("ActionPlanCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  items ActionItem[]
}

model ActionItem {
  id              String      @id @default(cuid())
  actionPlanId    String
  actionPlan      ActionPlan  @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  assigneeId      String?
  assignee        User?       @relation("ActionItemAssignee", fields: [assigneeId], references: [id])
  dueDate         DateTime?
  status          String      @default("PENDING") // PENDING, IN_PROGRESS, DONE, BLOCKED
  priority        String      @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  sortOrder       Int         @default(0)
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ============================================================
// DOCUMENT LIBRARY (Phase 3C)
// ============================================================

model Document {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  name            String
  category        String   // POLICY, CERTIFICATE, AUDIT_REPORT, TEST_REPORT, PHOTO, BILL, TRAINING_MATERIAL, OTHER
  fileUrl         String   // Vercel Blob URL or external URL
  fileSize        Int?     // bytes
  mimeType        String?
  linkedToType    String?  // AUDIT, TRAINING, INSPECTION, CAPA, CERTIFICATION, SAVINGS_MEASURE, ACTION_PLAN
  linkedToId      String?  // ID of the linked entity
  description     String?
  uploadedById    String
  uploadedBy      User     @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// NOTIFICATIONS (Phase 4A)
// ============================================================

model Notification {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  userId      String    // Recipient
  user        User      @relation("NotificationRecipient", fields: [userId], references: [id])
  type        String    // CERT_EXPIRY, AUDIT_DUE, CAPA_OVERDUE, BILL_ANOMALY, SAFETY_RISK, INSPECTION_DUE, ACTION_OVERDUE, SYSTEM
  title       String
  message     String
  severity    String    @default("INFO") // INFO, WARNING, CRITICAL
  isRead      Boolean   @default(false)
  actionUrl   String?   // Deep link to relevant page
  entityType  String?   // The entity this notification relates to
  entityId    String?
  createdAt   DateTime  @default(now())
}

// ============================================================
// GOVERNMENT SCHEMES & SUBSIDIES (Phase 4C)
// ============================================================

model GovernmentScheme {
  id              String   @id @default(cuid())
  name            String   // e.g., "ZED Certification Subsidy"
  shortName       String?  // e.g., "ZED"
  ministry        String?  // e.g., "MSME Ministry"
  description     String
  maxSubsidy      Float?   // ₹ maximum
  subsidyPercent  Float?   // % of cost
  eligibility     String?  // JSON: { industry, size, state, certifications }
  documentsNeeded String?  // Comma-separated list
  applicationUrl  String?  // Government portal link
  deadline        DateTime?
  isActive        Boolean  @default(true)
  category        String   // ENERGY, CERTIFICATION, EQUIPMENT, SKILL_DEVELOPMENT, GENERAL
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  applications SchemeApplication[]
}

model SchemeApplication {
  id              String           @id @default(cuid())
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id])
  schemeId        String
  scheme          GovernmentScheme @relation(fields: [schemeId], references: [id])
  appliedById     String
  appliedBy       User             @relation("SchemeApplicant", fields: [appliedById], references: [id])
  applicationDate DateTime         @default(now())
  applicationRef  String?          // Government reference number
  status          String           @default("IDENTIFIED") // IDENTIFIED, DOCUMENTS_READY, APPLIED, UNDER_REVIEW, APPROVED, DISBURSED, REJECTED
  amountApplied   Float?           // ₹
  amountApproved  Float?           // ₹
  amountDisbursed Float?           // ₹
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([clientId, schemeId])
}

// ============================================================
// SHAREABLE VIEWS (Phase 4D — Vendor Qualification)
// ============================================================

model ShareableView {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  token       String    @unique // Random token for public URL
  title       String    @default("Compliance Dashboard")
  sections    String?   // JSON: which sections to show (compliance, certifications, safety, etc.)
  isActive    Boolean   @default(true)
  expiresAt   DateTime? // Optional expiry
  viewCount   Int       @default(0)
  lastViewedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
